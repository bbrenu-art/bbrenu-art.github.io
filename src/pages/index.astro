---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO — fixed, fades on scroll              -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="hero" class="hero">
    <div class="hero-grid"></div>

    <div class="hero-content">
      <span class="hero-tag">// portfolio v1.0</span>

      <h1 class="hero-title">
        Bbrenu<span class="cursor-blink"></span>
      </h1>

      <p class="hero-subtitle">Pixel Artist &amp; Indie Game Developer</p>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-text">SCROLL</span>
      <span class="scroll-arrow">▼</span>
    </div>
  </section>

  <!-- Spacer that lets the hero show through -->
  <div class="hero-spacer"></div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- MAIN CONTENT — slides over the hero        -->
  <!-- ═══════════════════════════════════════════ -->
  <main class="content">
    <div class="content-edge" aria-hidden="true"></div>

    <!-- ── Gallery ────────────────────────────── -->
    <section class="gallery">
      <h2 class="section-title">// SELECTED WORKS</h2>

      <div class="gallery-grid">
        <!-- Column 1 — Monsters -->
        <div class="gallery-column col-monsters">
          <h3 class="column-title">
            <span class="col-dot dot-rose"></span>MONSTERS
          </h3>

          <div class="gallery-item" style="--tilt:-1.2deg; --w:100%; --delay:0s">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">monster_01.png</span>
              </div>
              <img src="/gallery/monster1.png" alt="Criatura aranha monstruosa em pixel art — fundo ocre" loading="lazy" />
            </div>
          </div>

          <div class="gallery-item" style="--tilt:2deg; --w:78%; --delay:.12s; align-self:flex-end">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">monster_02.png</span>
              </div>
              <img src="/gallery/monster2.png" alt="Criatura tentacular ciclope em pixel art — fundo rosa" loading="lazy" />
            </div>
          </div>

          <div class="gallery-item" style="--tilt:-2.8deg; --w:65%; --delay:.24s; align-self:center">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">monster_03.png</span>
              </div>
              <img src="/gallery/monster3.png" alt="Criatura alada verde em pixel art — fundo roxo" loading="lazy" />
            </div>
          </div>
        </div>

        <!-- Column 2 — Portraits -->
        <div class="gallery-column col-portraits">
          <h3 class="column-title">
            <span class="col-dot dot-gold"></span>PORTRAITS
          </h3>

          <div class="gallery-item" style="--tilt:1.8deg; --w:75%; --delay:.08s; align-self:flex-end">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">portrait_02.png</span>
              </div>
              <img src="/gallery/portrait2.png" alt="Retrato pixel art de mulher com vestido floral — fundo verde" loading="lazy" />
            </div>
          </div>

          <div class="gallery-item" style="--tilt:-0.6deg; --w:100%; --delay:.18s">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">portrait_01.png</span>
              </div>
              <img src="/gallery/portrait1.png" alt="Retrato pixel art de mulher com óculos — fundo azul acinzentado" loading="lazy" />
            </div>
          </div>

          <div class="gallery-item" style="--tilt:2.5deg; --w:70%; --delay:.28s; align-self:flex-start">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">portrait_03.png</span>
              </div>
              <img src="/gallery/portrait3.png" alt="Retrato pixel art de mulher com brincos — fundo terracota" loading="lazy" />
            </div>
          </div>
        </div>

        <!-- Column 3 — Environments -->
        <div class="gallery-column col-environments">
          <h3 class="column-title">
            <span class="col-dot dot-teal"></span>ENVIRONMENTS
          </h3>

          <div class="gallery-item" style="--tilt:-1.5deg; --w:100%; --delay:.15s">
            <div class="pixel-window">
              <div class="window-bar">
                <span class="bar-dot bd-red"></span>
                <span class="bar-dot bd-yellow"></span>
                <span class="bar-dot bd-green"></span>
                <span class="bar-title">architecture.png</span>
              </div>
              <img src="/gallery/architecture.png" alt="Casa isométrica em pixel art com carro e jardim — fundo azul" loading="lazy" />
            </div>
          </div>

          <div class="env-placeholder">
            <span class="placeholder-border"></span>
            <p>More worlds<br />coming soon...</p>
            <span class="placeholder-border"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Social links ───────────────────────── -->
    <section class="socials">
      <h2 class="section-title">// CONNECT</h2>

      <nav class="social-grid">
        <a href="mailto:brenofseixas3@gmail.com" class="social-link" id="email-link" data-email="brenofseixas3@gmail.com">
          <span class="social-arrow">►</span>
          <span class="social-name">EMAIL</span>
          <span class="social-handle" id="email-handle">brenofseixas3@gmail.com</span>
        </a>

        <a href="https://instagram.com" target="_blank" rel="noopener" class="social-link">
          <span class="social-arrow">►</span>
          <span class="social-name">INSTAGRAM</span>
          <span class="social-handle">instagram.com</span>
        </a>

        <a href="https://www.linkedin.com/in/breno-seixas-6b8497373/" target="_blank" rel="noopener" class="social-link">
          <span class="social-arrow">►</span>
          <span class="social-name">LINKEDIN</span>
          <span class="social-handle">linkedin.com/in/breno-seixas</span>
        </a>
      </nav>
    </section>

    <!-- ── Footer ─────────────────────────────── -->
    <footer class="footer">
      <p>&copy; 2026 Bbrenu &middot; Made with pixels</p>
    </footer>
  </main>

  <!-- ═══════════════════════════════════════════ -->
  <!-- LIGHTBOX                                    -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-window">
      <div class="lightbox-bar">
        <span class="bar-dot bd-red"></span>
        <span class="bar-dot bd-yellow"></span>
        <span class="bar-dot bd-green"></span>
        <span class="lightbox-filename" id="lightbox-filename"></span>
        <button class="lightbox-close" id="lightbox-close" aria-label="Fechar">✕</button>
      </div>
      <div class="lightbox-body">
        <img id="lightbox-img" src="" alt="" />
      </div>
    </div>
  </div>
</Layout>

<!-- ═══════════════════════════════════════════════ -->
<!-- SCROLL  LOGIC                                  -->
<!-- ═══════════════════════════════════════════════ -->
<script>
  const hero = document.getElementById("hero") as HTMLElement;
  let ticking = false;

  function onScroll() {
    const y = window.scrollY;
    const h = window.innerHeight;
    const progress = Math.min(y / h, 1);

    hero.style.opacity = String(1 - progress);
    hero.style.transform = `scale(${1 + progress * 0.08})`;
    hero.style.filter = `blur(${progress * 5}px)`;

    ticking = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    },
    { passive: true },
  );

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
  );

  document.querySelectorAll(".gallery-item, .social-link, .env-placeholder").forEach((el) => {
    observer.observe(el);
  });

  const emailLink = document.getElementById("email-link") as HTMLAnchorElement;
  const emailHandle = document.getElementById("email-handle") as HTMLElement;
  const email = emailLink.dataset.email!;

  emailLink.addEventListener("click", () => {
    navigator.clipboard.writeText(email).then(() => {
      const original = emailHandle.textContent;
      emailHandle.textContent = "copied to clipboard!";
      emailHandle.classList.add("copied");

      setTimeout(() => {
        emailHandle.textContent = original;
        emailHandle.classList.remove("copied");
      }, 2000);
    });
  });

  /* ── Lightbox ──────────────────────────────── */
  const lightbox = document.getElementById("lightbox") as HTMLElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lightboxName = document.getElementById("lightbox-filename") as HTMLElement;
  const lightboxClose = document.getElementById("lightbox-close") as HTMLButtonElement;
  const lightboxBackdrop = lightbox.querySelector(".lightbox-backdrop") as HTMLElement;

  function openLightbox(src: string, alt: string, filename: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightboxName.textContent = filename;
    lightbox.setAttribute("aria-hidden", "false");
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.remove("open");
    lightbox.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.querySelectorAll(".gallery-item .pixel-window").forEach((win) => {
    win.addEventListener("click", () => {
      const img = win.querySelector("img") as HTMLImageElement;
      const title = win.querySelector(".bar-title") as HTMLElement;
      openLightbox(img.src, img.alt, title.textContent || "");
    });
  });

  lightboxClose.addEventListener("click", closeLightbox);
  lightboxBackdrop.addEventListener("click", closeLightbox);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightbox.classList.contains("open")) {
      closeLightbox();
    }
  });
</script>

<!-- ═══════════════════════════════════════════════ -->
<!-- STYLES                                         -->
<!-- ═══════════════════════════════════════════════ -->
<style>
  /* ── Hero ─────────────────────────────────────── */
  .hero {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    will-change: opacity, transform, filter;
    overflow: hidden;
  }

  /* Subtle pixel-grid background */
  .hero-grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px),
      radial-gradient(ellipse at 50% 38%, rgba(35, 40, 70, 0.55) 0%, var(--bg-deep) 72%);
    background-size:
      32px 32px,
      32px 32px,
      100% 100%;
    pointer-events: none;
  }

  /* CRT scanline overlay */
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 0, 0, 0.06) 3px,
      rgba(0, 0, 0, 0.06) 6px
    );
    pointer-events: none;
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  .hero-title {
    font-family: var(--font-pixel);
    font-size: clamp(4rem, 13vw, 11rem);
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: 0.04em;
    text-shadow:
      0 0 30px rgba(212, 168, 67, 0.25),
      0 0 60px rgba(212, 168, 67, 0.12),
      0 0 120px rgba(212, 168, 67, 0.06);
  }

  .cursor-blink {
    display: inline-block;
    width: 0.45em;
    height: 0.85em;
    background: var(--accent-gold);
    margin-left: 0.08em;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: clamp(0.7rem, 1.8vw, 1.05rem);
    color: var(--text-secondary);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-text {
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.35em;
  }

  .scroll-arrow {
    font-size: 0.8rem;
    color: var(--accent-gold);
    animation: bounce 1.8s ease-in-out infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* ── Spacer + content ────────────────────────── */
  .hero-spacer {
    height: 100vh;
    position: relative;
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    background: var(--bg-deep);
  }

  .content-edge {
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--accent-rose),
      var(--accent-gold),
      var(--accent-teal),
      var(--accent-purple)
    );
  }

  /* ── Section title ───────────────────────────── */
  .section-title {
    font-family: var(--font-pixel);
    font-size: clamp(1.1rem, 2.8vw, 1.6rem);
    color: var(--accent-gold);
    text-align: center;
    letter-spacing: 0.15em;
    margin-bottom: 4rem;
  }

  /* ── Gallery ─────────────────────────────────── */
  .gallery {
    padding: 5rem 2rem 6rem;
    max-width: 1300px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .gallery-column {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .column-title {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--text-secondary);
    letter-spacing: 0.22em;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .col-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
  }
  .dot-rose {
    background: var(--accent-rose);
  }
  .dot-gold {
    background: var(--accent-gold);
  }
  .dot-teal {
    background: var(--accent-teal);
  }

  /* ── Gallery item (entry animation) ──────────── */
  .gallery-item {
    width: var(--w, 100%);
    opacity: 0;
    transform: translateY(36px) rotate(var(--tilt, 0deg));
    transition:
      opacity 0.65s ease,
      transform 0.65s ease;
    transition-delay: var(--delay, 0s);
    position: relative;
    cursor: pointer;
  }

  .gallery-item.visible {
    opacity: 1;
    transform: translateY(0) rotate(var(--tilt, 0deg));
  }

  .gallery-item:hover {
    z-index: 10;
    transform: translateY(-4px) rotate(0deg) scale(1.03) !important;
  }

  /* ── Pixel window frame ──────────────────────── */
  .pixel-window {
    border: 2px solid var(--border-light);
    background: var(--bg-card);
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .window-bar {
    background: var(--bg-elevated);
    padding: 7px 10px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 2px solid var(--border-color);
  }

  .bar-dot {
    width: 8px;
    height: 8px;
  }
  .bd-red {
    background: #c05050;
  }
  .bd-yellow {
    background: #c0a040;
  }
  .bd-green {
    background: #50a060;
  }

  .bar-title {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-left: auto;
  }

  .pixel-window img {
    width: 100%;
    display: block;
  }

  /* Hover glow per category */
  .col-monsters .gallery-item:hover .pixel-window {
    border-color: var(--accent-rose);
    box-shadow:
      0 0 16px rgba(192, 112, 96, 0.25),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }
  .col-portraits .gallery-item:hover .pixel-window {
    border-color: var(--accent-gold);
    box-shadow:
      0 0 16px rgba(212, 168, 67, 0.25),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }
  .col-environments .gallery-item:hover .pixel-window {
    border-color: var(--accent-teal);
    box-shadow:
      0 0 16px rgba(107, 158, 138, 0.25),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }

  /* ── Environments placeholder ────────────────── */
  .env-placeholder {
    border: 2px dashed var(--border-color);
    padding: 3rem 1.5rem;
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    line-height: 1.8;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease 0.3s,
      transform 0.5s ease 0.3s;
  }

  .env-placeholder.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .placeholder-border {
    display: block;
    width: 40px;
    height: 2px;
    background: var(--border-color);
    margin: 0.8rem auto;
  }

  /* ── Social links ────────────────────────────── */
  .socials {
    padding: 4rem 2rem 5rem;
    max-width: 620px;
    margin: 0 auto;
  }

  .social-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.4rem;
    border: 2px solid var(--border-color);
    border-bottom: none;
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
    opacity: 0;
    transform: translateX(-20px);
  }

  .social-link.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .social-link:last-child {
    border-bottom: 2px solid var(--border-color);
  }

  .social-link:hover {
    background: rgba(212, 168, 67, 0.06);
    border-color: var(--accent-gold);
    transform: translateX(6px);
  }

  .social-link:hover + .social-link {
    border-top-color: var(--accent-gold);
  }

  .social-arrow {
    color: var(--accent-gold);
    font-size: 0.7rem;
    transition: transform 0.2s ease;
  }

  .social-link:hover .social-arrow {
    transform: translateX(3px);
  }

  .social-name {
    color: var(--text-primary);
  }

  .social-handle {
    margin-left: auto;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    transition: color 0.25s ease;
  }

  .social-handle.copied {
    color: var(--accent-teal);
  }

  /* ── Footer ──────────────────────────────────── */
  .footer {
    text-align: center;
    padding: 3rem 2rem;
    border-top: 1px solid var(--border-color);
  }

  .footer p {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  /* ── Lightbox ─────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .lightbox.open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 7, 12, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .lightbox-window {
    position: relative;
    max-width: min(90vw, 800px);
    max-height: 88vh;
    border: 2px solid var(--border-light);
    background: var(--bg-card);
    overflow: hidden;
    transform: scale(0.92) translateY(12px);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lightbox.open .lightbox-window {
    transform: scale(1) translateY(0);
  }

  .lightbox-bar {
    background: var(--bg-elevated);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 2px solid var(--border-color);
  }

  .lightbox-filename {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-secondary);
    margin-left: auto;
    margin-right: 0.5rem;
  }

  .lightbox-close {
    background: none;
    border: 2px solid var(--border-color);
    color: var(--text-muted);
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    width: 28px;
